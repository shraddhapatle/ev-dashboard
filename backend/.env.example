# Copy this file to `.env` and adjust values for your machine.

# Port the Express API listens on
PORT=5000

# Local MongoDB connection string (database name = sajag_db)
MONGO_URI=mongodb://localhost:27017/sajag_db

# Comma-separated browser origins allowed by CORS.
# Leave blank to reflect ALL origins (local POC only).
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173
